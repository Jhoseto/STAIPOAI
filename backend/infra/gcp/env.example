## Shared
PROJECT_ID=your-gcp-project
REGION=europe-west3

## Cloud SQL
# Recommended format for services/ai-data
DATABASE_URL=postgresql+psycopg://staipo:staipo@HOST:5432/staipo

## Cloud Run URLs
AI_DATA_URL=https://staipo-ai-data-xxxxx.a.run.app

## Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL_FAST=gemini-3.1-flash-lite-preview
GEMINI_MODEL_FLAGSHIP=gemini-3-flash-preview
GEMINI_ENABLE_GOOGLE_SEARCH=true
GEMINI_THINKING_BUDGET=24576
GEMINI_MIN_ACCEPT_CONFIDENCE=0.8
GEMINI_IMAGE_MODE=fast
GEMINI_IMAGE_MODEL_FAST=gemini-2.5-flash-image
GEMINI_IMAGE_MODEL_PREMIUM=gemini-3-pro-image-preview

## NextAuth (optional for production)
NEXTAUTH_URL=https://staipo-web-xxxxx.a.run.app
NEXTAUTH_SECRET=change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

